@model HRM.Web.ViewModels.RoleModificationViewModel

@{
    var isEditMode = Model.RoleId > 0;
    ViewData["Title"] = isEditMode ? "Edit Role" : "Create Role";
}

<h1>@ViewData["Title"]</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Modify">
            <input type="hidden" asp-for="RoleId" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Permissions</label>
                <div class="card p-3">
                    @for (var i = 0; i < Model.Permissions.Count; i++)
                    {
                        <div class="form-check">
                            <input type="hidden" asp-for="Permissions[i].PermissionId" />
                            <input type="hidden" asp-for="Permissions[i].Name" />
                            <input asp-for="Permissions[i].IsAssigned" class="form-check-input" />
                            <label class="form-check-label" asp-for="Permissions[i].IsAssigned">
                                @Model.Permissions[i].Name
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
